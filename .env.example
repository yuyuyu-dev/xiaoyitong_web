# ========================================
# 校易通 环境变量配置
# 复制本文件为 .env：  cp .env.example .env
# 然后修改下面的值即可
# ========================================

# ---------- 数据库 ----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的MySQL密码
DB_NAME=xiaoyitongweb

# ---------- 安全密钥（必填，用于 JWT 签名） ----------
# 生成方法：在终端运行 node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ---------- 服务器 ----------
NODE_ENV=development
PORT=3000

# ---------- 邮件（不填也能跑，注册验证码不会真的发送） ----------
# QQ邮箱配置示例：
#   SMTP_HOST=smtp.qq.com
#   SMTP_PORT=465
#   SMTP_USER=你的QQ号@qq.com
#   SMTP_PASS=QQ邮箱授权码（QQ邮箱→设置→账户→POP3/SMTP服务→开启→生成授权码）
#   SMTP_FROM=你的QQ号@qq.com
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
